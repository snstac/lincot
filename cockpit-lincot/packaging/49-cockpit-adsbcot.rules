// -*- mode: javascript -*-
// Allow Cockpit (via cockpit-bridge) to manage ADSBCOT config and TLS paths for sudo-capable users.

polkit.addRule(function(action, subject) {
    if (
        action.id == "org.freedesktop.policykit.exec" &&
        action.lookup("program") == "/usr/libexec/cockpit-bridge" &&
        subject.isInGroup("sudo")
    ) {
        return polkit.Result.YES;
    }

    if (action.id == "org.freedesktop.cockpit.file") {
        var path = action.lookup("path");
        if (
            path == "/etc/default/adsbcot" ||
            (typeof path == "string" && path.indexOf("/etc/adsbcot/tls/") === 0)
        ) {
            if (subject.isInGroup("sudo")) {
                return polkit.Result.YES;
            }
        }
    }
});
